<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="GrawjiPreferencesDialog" parent="AdwPreferencesDialog">
    <child>
      <object class="AdwPreferencesPage">
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title">Appearance</property>
            <child>
              <object class="AdwComboRow" id="color_scheme_row">
                <property name="title">Theme</property>
                <property name="subtitle">Follow the desktop, or force a light or dark UI</property>
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">Follow system</item>
                      <item translatable="yes">Light</item>
                      <item translatable="yes">Dark</item>
                    </items>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title">Behaviour</property>
            <child>
              <object class="AdwSwitchRow" id="load_recipe_row">
                <property name="title">Load recipe from selected image</property>
                <property name="subtitle">Off: keep the current recipe and apply it to each image</property>
              </object>
            </child>
            <child>
              <object class="AdwSwitchRow" id="wb_grid_row">
                <property name="title">Tint the white-balance shift grid</property>
                <property name="subtitle">Colour each cell with the shift it applies</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <property name="title">Export</property>
            <child>
              <object class="AdwActionRow">
                <property name="title">JPEG quality</property>
                <property name="subtitle">Higher means a larger file</property>
                <child type="suffix">
                  <object class="GtkScale" id="jpeg_quality_scale">
                    <property name="valign">center</property>
                    <property name="hexpand">true</property>
                    <property name="width-request">200</property>
                    <property name="draw-value">true</property>
                    <property name="value-pos">left</property>
                    <property name="digits">0</property>
                    <property name="adjustment">
                      <object class="GtkAdjustment">
                        <property name="lower">1</property>
                        <property name="upper">100</property>
                        <property name="step-increment">1</property>
                        <property name="page-increment">10</property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="AdwSwitchRow" id="batch_skip_row">
                <property name="title">Skip other cameras on batch export</property>
                <property name="subtitle">Ignore RAFs from a different body and carry on, instead of stopping</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
