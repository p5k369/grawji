<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <menu id="main_menu">
    <section>
      <item>
        <attribute name="label">Manage Recipes…</attribute>
        <attribute name="action">win.manage-recipes</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Show Histogram</attribute>
        <attribute name="action">win.toggle-histogram</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">Keyboard Shortcuts</attribute>
        <attribute name="action">win.shortcuts</attribute>
      </item>
      <item>
        <attribute name="label">Preferences</attribute>
        <attribute name="action">win.preferences</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label">About grawji</attribute>
        <attribute name="action">win.about</attribute>
      </item>
    </section>
  </menu>
  <menu id="export_menu">
    <section>
      <item>
        <attribute name="label">Batch Export…</attribute>
        <attribute name="action">win.batch-export</attribute>
      </item>
    </section>
  </menu>
  <template class="MainWindow" parent="AdwApplicationWindow">
    <property name="default-width">1360</property>
    <property name="default-height">880</property>
    <property name="content">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="title-widget">
              <object class="AdwWindowTitle" id="window_title">
                <property name="title">grawji</property>
                <property name="subtitle">No camera</property>
              </object>
            </property>
            <child type="start">
              <object class="GtkButton" id="sidebar_button">
                <property name="icon-name">sidebar-show-symbolic</property>
                <property name="tooltip-text">Collapse or show the side panel</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkMenuButton">
                <property name="icon-name">open-menu-symbolic</property>
                <property name="tooltip-text">Menu</property>
                <property name="menu-model">main_menu</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton">
                <property name="icon-name">preferences-system-symbolic</property>
                <property name="tooltip-text">Preferences (Ctrl+,)</property>
                <property name="action-name">win.preferences</property>
              </object>
            </child>
            <child type="end">
              <object class="AdwSplitButton" id="export_button">
                <property name="label">Export…</property>
                <property name="sensitive">false</property>
                <property name="menu-model">export_menu</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkPaned" id="main_paned">
                <property name="vexpand">true</property>
                <property name="resize-start-child">false</property>
                <property name="shrink-start-child">true</property>
                <property name="start-child">
                  <object class="GtkBox" id="left_panel">
                    <property name="orientation">vertical</property>
                    <property name="width-request">0</property>
                    <property name="spacing">6</property>
                    <property name="margin-start">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-top">10</property>
                    <property name="margin-bottom">10</property>
                    <child>
                      <object class="AdwViewSwitcher">
                        <property name="stack">left_stack</property>
                        <property name="policy">wide</property>
                      </object>
                    </child>
                    <child>
                      <object class="AdwViewStack" id="left_stack">
                        <property name="vexpand">true</property>
                        <child>
                          <object class="AdwViewStackPage">
                            <property name="name">browse</property>
                            <property name="title">Browse</property>
                            <property name="icon-name">folder-symbolic</property>
                            <property name="child">
                              <object class="GtkBox" id="foldertree_slot">
                                <property name="orientation">vertical</property>
                                <property name="vexpand">true</property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="AdwViewStackPage">
                            <property name="name">info</property>
                            <property name="title">Info</property>
                            <property name="icon-name">image-x-generic-symbolic</property>
                            <property name="child">
                              <object class="GtkScrolledWindow">
                                <property name="hscrollbar-policy">never</property>
                                <property name="vexpand">true</property>
                                <child>
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">8</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Original</property>
                                        <property name="xalign">0</property>
                                        <style>
                                          <class name="heading"/>
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkFrame">
                                        <property name="overflow">hidden</property>
                                        <property name="height-request">180</property>
                                        <style>
                                          <class name="card"/>
                                        </style>
                                        <child>
                                          <object class="GtkOverlay">
                                            <property name="child">
                                              <object class="GtkPicture" id="original_picture">
                                                <property name="content-fit">contain</property>
                                              </object>
                                            </property>
                                            <child type="overlay">
                                              <object class="GtkDrawingArea" id="nav_overlay"/>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwPreferencesGroup" id="exif_group">
                                        <property name="title">Image info</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="end-child">
                  <object class="GtkPaned">
                    <property name="resize-end-child">false</property>
                    <property name="shrink-end-child">false</property>
                    <property name="start-child">
                      <object class="GrawjiPreviewView" id="preview_view"/>
                    </property>
                    <property name="end-child">
                      <object class="GrawjiRecipePanel" id="recipe_panel"/>
                    </property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkSeparator"/>
            </child>
            <child>
              <object class="GtkBox" id="filmstrip_slot">
                <property name="orientation">horizontal</property>
                <property name="spacing">2</property>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
