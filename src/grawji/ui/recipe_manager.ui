<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="GrawjiRecipeManagerDialog" parent="AdwDialog">
    <property name="title">Manage recipes</property>
    <property name="content-width">1040</property>
    <property name="content-height">880</property>
    <property name="child">
      <object class="AdwToastOverlay" id="toasts">
      <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="start">
              <object class="GtkButton" id="import_button">
                <property name="label">Import…</property>
                <property name="tooltip-text">Import an X RAW Studio recipe</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="transfer_button">
                <property name="label">Transfer to camera</property>
                <property name="tooltip-text">Write the assigned recipes into the camera's custom banks</property>
                <style>
                  <class name="suggested-action"/>
                </style>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="new_folder_button">
                <property name="icon-name">folder-new-symbolic</property>
                <property name="tooltip-text">New folder</property>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <child>
              <object class="GtkStack" id="stack">
                <property name="hexpand">true</property>
                <child>
                  <object class="GtkStackPage">
                    <property name="name">list</property>
                    <property name="child">
                      <object class="GtkScrolledWindow">
                        <property name="hscrollbar-policy">never</property>
                        <property name="vexpand">true</property>
                        <property name="child">
                          <object class="AdwPreferencesPage" id="content"/>
                        </property>
                      </object>
                    </property>
                  </object>
                </child>
                <child>
                  <object class="GtkStackPage">
                    <property name="name">empty</property>
                    <property name="child">
                      <object class="AdwStatusPage">
                        <property name="icon-name">emblem-documents-symbolic</property>
                        <property name="title">No recipes</property>
                        <property name="description">Import a recipe, or save the current settings.</property>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkSeparator">
                <property name="orientation">vertical</property>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="width-request">400</property>
                <property name="spacing">10</property>
                <property name="margin-start">16</property>
                <property name="margin-end">16</property>
                <property name="margin-top">16</property>
                <property name="margin-bottom">16</property>
                <child>
                  <object class="GtkBox">
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkImage" id="camera_image">
                        <property name="pixel-size">44</property>
                        <property name="icon-name">camera-photo-symbolic</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="camera_header">
                        <property name="xalign">0</property>
                        <property name="label">Camera</property>
                        <style>
                          <class name="title-4"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkStack" id="camera_stack">
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">banks</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <property name="vexpand">true</property>
                            <property name="overlay-scrolling">false</property>
                            <property name="child">
                              <object class="GtkBox" id="camera_banks">
                                <property name="orientation">vertical</property>
                                <property name="spacing">10</property>
                                <property name="margin-end">6</property>
                              </object>
                            </property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">none</property>
                        <property name="child">
                          <object class="AdwStatusPage" id="camera_none_page">
                            <property name="icon-name">camera-photo-symbolic</property>
                            <property name="title">No camera</property>
                            <property name="description">Connect a body in USB RAW CONV./BACKUP RESTORE mode to assign recipes to its banks.</property>
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
      </property>
      </object>
    </property>
  </template>
</interface>
